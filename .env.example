# AxumRouter Backend — Environment Variables
# Copy this to .env and fill in your values.

# Database path (default: data/axumrouter.db)
DATABASE_URL=sqlite:data/axumrouter.db?mode=rwc

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Gateway
GATEWAY_TIMEOUT_SECS=120

# Auth
AUTH_API_KEY_HEADER=Authorization
AUTH_API_KEY_PREFIX=Bearer

# Public IP (auto-detected if empty)
PUBLIC_IP=

# OAuth Redirect URLs (override for production)
# OAUTH_CX_REDIRECT_URI=http://localhost:3000/admin/oauth/cx/callback
# OAUTH_XAI_REDIRECT_URI=http://localhost:3000/admin/oauth/xai/callback
