# AxumRouter Backend — .env
#
# Semua env yang dibaca oleh AxumRouter.
# Format: AXUM_<SECTION>__<FIELD> (double underscore = nested field)
# Config priority: env var (AXUM_) > config/config.toml
#
# Bisa juga pakai config/config.toml — pilih salah satu aja.
# Kalo pake config.toml, env vars di file ini gak perlu diisi.

# ── Server ──────────���───────────────────────────────────
AXUM_SERVER__HOST=0.0.0.0
AXUM_SERVER__PORT=7444
# AXUM_SERVER__PUBLIC_URL=http://vps-ip:7444

# ── Database ────────────────────────────────────────────
AXUM_DATABASE__URL=sqlite:data/dev.db?mode=rwc

# ── Gateway ─────────────────────────────────────────────
AXUM_GATEWAY__TIMEOUT_SECS=120

# ── Auth ────────────────────────────────────────────────
AXUM_AUTH__ADMIN_PASSWORD=admin
AXUM_AUTH__JWT_SECRET=dev-secret-axumrouter-2026
# AXUM_AUTH__API_KEY_HEADER=Authorization
# AXUM_AUTH__API_KEY_PREFIX=Bearer

# ── Logging ─────────────────────────────────────────────
RUST_LOG=info
# RUST_LOG_FORMAT=json
