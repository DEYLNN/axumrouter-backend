# AxumRouter Backend — Environment Variables
# Copy this to .env and fill in your values.
# Env vars use AXUM_ prefix (loaded by config crate).
# Also reads from config/config.toml.

# Database path (default: data/axumrouter.db)
AXUM_DATABASE__URL=sqlite:data/axumrouter.db?mode=rwc

# Server
AXUM_SERVER__HOST=0.0.0.0
AXUM_SERVER__PORT=3000

# Gateway
AXUM_GATEWAY__TIMEOUT_SECS=120

# Auth
AXUM_AUTH__API_KEY_HEADER=***
AXUM_AUTH__API_KEY_PREFIX=***

# Public IP (auto-detected if empty)
AXUM_PUBLIC_IP=

# Logging
RUST_LOG=info
RUST_LOG_FORMAT=
